#!groovy

@Library("Infrastructure@2.4.4")

def type = "nodejs"
def product = "fact"
def component = "admin-frontend"

def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

def secrets = [
  'fact-bstrap-${env}-kv': [
    secret('sso-test-admin-email', 'SSO_TEST_ADMIN_EMAIL'),
    secret('sso-test-admin-password', 'SSO_TEST_ADMIN_PASSWORD'),
    secret('sso-test-super-admin-email', 'SSO_TEST_SUPER_ADMIN_EMAIL'),
    secret('sso-test-super-admin-password', 'SSO_TEST_SUPER_ADMIN_PASSWORD'),
    secret('sso-test-viewer-email', 'SSO_TEST_VIEWER_EMAIL'),
    secret('sso-test-viewer-password', 'SSO_TEST_VIEWER_PASSWORD'),
  ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

withPipeline(type, product, component) {
  env.DATA_API_URL = 'https://fact-data-api-pr-319.preview.platform.hmcts.net'
  env.PLAYWRIGHT_WORKERS = 4

  loadVaultSecrets(secrets)

  afterSuccess('akschartsinstall') {
    yarnBuilder.yarn('build')
  }

  before('smoketest:preview') {
    yarnBuilder.yarn('playwright install')
  }

  before('smoketest:aat') {
    yarnBuilder.yarn('playwright install')
  }

  before('functionalTest:preview') {
    yarnBuilder.yarn('playwright install')
  }

  before('functionalTest:aat') {
    yarnBuilder.yarn('playwright install')
  }

  // Report publishing

  env.PLAYWRIGHT_REPORTERS = 'list,odhin'
  env.PLAYWRIGHT_VIDEO_MODE = 'retain-on-failure'

  afterAlways('functionalTest:preview') {
    publishHTML target: [
      allowMissing          : true,
      alwaysLinkToLastBuild : true,
      keepAll               : true,
      reportDir             : 'test-results',
      reportFiles           : 'odhin-report/index.html,lighthouse-report-*.html',
      reportName            : 'Functional Test Report',
    ]
  }

  afterAlways('smoketest:preview') {
    publishHTML target: [
      allowMissing          : true,
      alwaysLinkToLastBuild : true,
      keepAll               : true,
      reportDir             : 'test-results',
      reportFiles           : 'odhin-report/index.html',
      reportName            : 'Smoke Test Report',
    ]
  }

  afterAlways('functionalTest:aat') {
    publishHTML target: [
      allowMissing          : true,
      alwaysLinkToLastBuild : true,
      keepAll               : true,
      reportDir             : 'test-results',
      reportFiles           : 'odhin-report/index.html,lighthouse-report-*.html',
      reportName            : 'Functional Test Report',
    ]
  }

  afterAlways('smoketest:aat') {
    publishHTML target: [
      allowMissing          : true,
      alwaysLinkToLastBuild : true,
      keepAll               : true,
      reportDir             : 'test-results',
      reportFiles           : 'odhin-report/index.html',
      reportName            : 'Smoke Test Report',
    ]
  }

  syncBranchesWithMaster(['demo', 'perftest', 'ithc'])
}
