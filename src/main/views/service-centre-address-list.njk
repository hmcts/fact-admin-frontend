{% extends "template.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}
{% from "macros/common-components.njk" import addressBlock, addressType, rowActions %}

{% block pageTitle %}
  {{ pageTitle }}
{% endblock %}

{% block content %}
  {% set addressTableRows = [] %}
  {% if serviceCentreAddresses.length %}
    {% for address in serviceCentreAddresses %}
      {% set addressTableRows = (addressTableRows.push([
        {
          html: addressType(address)
        },
        {
          html: addressBlock(address)
        },
        {
          html: rowActions([
            {
              href: '/service-centres/' + serviceCentreId + '/edit/address/find/' + address.id,
              text: 'Edit'
            },
            {
              href: '/service-centres/' + serviceCentreId + '/edit/address/delete/' + address.id,
              text: 'Delete'
            }
          ])
        }
      ]), addressTableRows) %}
    {% endfor %}
  {% endif %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <h1 class="govuk-heading-l">Address</h1>
      <span class="govuk-caption-l">You can have 0-1 addresses per service centre</span>

      {% if serviceCentreAddresses.length === 0 %}
        {{ govukWarningText({
          text: "If you do not add an address, this service centre will be marked as closed.",
          iconFallbackText: "Warning"
        }) }}
      {% endif %}

      {% if addressTableRows.length %}
        {{ govukTable({
          firstCellIsHeader: false,
          head: [
            {
              text: "Address type",
              classes: "govuk-!-width-one-quarter"
            },
            {
              text: "Address",
              classes: "govuk-!-width-one-half"
            },
            {
              text: "Actions",
              classes: "govuk-!-width-one-quarter"
            }
          ],
          rows: addressTableRows
        }) }}
      {% else %}
        <p class="govuk-body">No addresses are currently configured.</p>
      {% endif %}

      {% if serviceCentreAddresses.length === 0 %}
        {{ govukButton({
          text: "Add address",
          href: '/service-centres/' + serviceCentreId + '/edit/address/find'
        }) }}
      {% endif %}
    </div>
  </div>
{% endblock %}

