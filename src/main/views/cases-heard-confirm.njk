{% extends "template.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}

{% block pageTitle %}
  Cases heard confirm update - {{ courtName }}
{% endblock %}

{% block content %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">Are you sure you want to save the changes to Cases Heard?</h1>

      <form method="post" action="/courts/{{ courtId }}/edit/cases-heard/success">

        {{ govukSummaryList({
          rows: [
            {
              key: { text: "Court name" },
              value: { text: courtName }
            },
            {
              key: { text: "Confirm" },
              value: { text: message }
            }
          ]
        }) }}

        <input type="hidden" name="areasOfLaw" value="{{ selectedAreasOfLaw }}">

        {{ govukButton({
          text: "Continue",
          classes: "govuk-button--warning"
        }) }}

      </form>
      <a href="/courts/{{ courtId }}/edit/cases-heard" class="govuk-link">Go back</a>
    </div>
  </div>

{% endblock %}
