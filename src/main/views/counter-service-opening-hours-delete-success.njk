{% extends "template.njk" %}
{% from "macros/common-components.njk" import successPanel %}

{% block pageTitle %}
  Counter service opening hours deleted
{% endblock %}

{% block content %}
  {{ successPanel("Opening hours deleted", assistanceAvailable) }}

  <p class="govuk-body govuk-!-text-align-center govuk-!-margin-bottom-6">
     You have removed this counter service opening hour for {{ courtName }}.
  </p>

  <p class="govuk-body govuk-!-font-weight-bold govuk-!-margin-top-6">What do you want to do next?</p>
  <ul class="govuk-list govuk-list--bullet">
    <li><a href="/courts/{{ courtId }}/edit/counter-service-opening-hours" class="govuk-link govuk-link--no-visited-state">Back to Counter service opening hours</a></li>
  </ul>
{% endblock %}
