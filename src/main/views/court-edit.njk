{% extends "template.njk" %}
{% from "macros/lock-status-edit-view.njk" import lockStatusEditView %}

{% block pageTitle %}
  {{ pageTitle }}
{% endblock %}

{% block content %}
  {% set editPath = '/courts/' + courtId + '/edit' %}
  {% set sections = [
    { href: editPath + '/accessibility', label: 'Accessibility', page: 'accessibility' },
    { href: editPath + '/address', label: 'Address', page: 'address' },
    { href: editPath + '/cases-heard', label: 'Cases heard', page: 'cases-heard' },
    { href: editPath + '/contact-details', label: 'Contact details', page: 'contact-details' },
    { href: editPath + '/counter-service-opening-hours', label: 'Counter service opening hours', page: 'counter-service-opening-hours' },
    { href: editPath + '/court-opening-hours', label: 'Court opening hours', page: 'court-opening-hours' },
    { href: editPath + '/general', label: 'General', page: 'general' },
    { href: editPath + '/building-facilities', label: 'Building facilities', page: 'building-facilities' },
    { href: editPath + '/information-for-professionals', label: 'Information for professionals', page: 'information-for-professionals' },
    { href: editPath + '/local-authorities', label: 'Local authorities', page: 'local-authorities' },
    { href: editPath + '/photo', label: 'Photo', page: 'photo' },
    { href: editPath + '/single-point-of-entry', label: 'Single points of entry', page: 'single-point-of-entry' },
    { href: editPath + '/translation-and-interpretation', label: 'Translation and interpretation', page: 'translation-and-interpretation' },
    { href: editPath + '/warning-notice', label: 'Warning notice', page: 'warning-notice' }
  ] %}
  {{ lockStatusEditView(
    "court",
    courtName,
    courtLocks,
    sections,
    timeoutMins,
    showApproveData,
    approvePath,
    isViewer)
  }}
{% endblock %}
