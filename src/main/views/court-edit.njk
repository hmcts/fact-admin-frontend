{% extends "template.njk" %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{% block pageTitle %}
  {{ pageTitle }}
{% endblock %}

{% block content %}
  {% set sections = [
    { href: '/courts/' + courtId + '/edit/accessibility', label: 'Accessibility', status: 'TODO' },
    { href: '/courts/' + courtId + '/edit/address', label: 'Address', status: 'TODO' },
    { href: '/courts/' + courtId + '/edit/building-facilities', label: 'Building facilities', status: 'TODO' },
    { href: '/courts/' + courtId + '/edit/cases-heard', label: 'Cases heard', status: 'TODO' },
    { href: '/courts/' + courtId + '/edit/contact-details', label: 'Contact details', status: 'TODO' },
    { href: '/courts/' + courtId + '/edit/counter-service-opening-hours', label: 'Counter service opening hours', status: 'TODO' },
    { href: '/courts/' + courtId + '/edit/court-opening-hours', label: 'Court opening hours', status: 'TODO' },
    { href: '/courts/' + courtId + '/edit/general', label: 'General', status: 'TODO' },
    { href: '/courts/' + courtId + '/edit/information-for-professionals', label: 'Information for professionals', status: 'TODO' },
    { href: '/courts/' + courtId + '/edit/local-authorities', label: 'Local authorities', status: 'TODO' },
    { href: '/courts/' + courtId + '/edit/photo', label: 'Photo', status: 'TODO' },
    { href: '/courts/' + courtId + '/edit/translation-and-interpretation', label: 'Translation and interpretation', status: 'TODO' },
    { href: '/courts/' + courtId + '/edit/warning-notice', label: 'Warning notice', status: 'TODO' }
  ] %}
  {% set sectionRows = [] %}
  {% for section in sections %}
    {% set statusId = "court-edit-" + loop.index + "-status" %}
    {% set sectionRows = (sectionRows.push([
      {
        html: '<a class="govuk-link" href="' + section.href + '" aria-describedby="' + statusId + '">' + section.label + '</a>'
      },
      {
        html: '<span id="' + statusId + '">' + govukTag({
          text: section.status,
          classes: "govuk-tag--grey"
        }) + '</span>'
      }
    ]), sectionRows) %}
  {% endfor %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <h1 class="govuk-heading-l">Editing - {{ courtName }}</h1>
      <div class="court-edit-table__wrapper">
        {{ govukTable({
          classes: "court-edit-table",
          firstCellIsHeader: false,
          rows: sectionRows
        }) }}
      </div>
    </div>
  </div>
{% endblock %}
