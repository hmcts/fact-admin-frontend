{% from "govuk/components/panel/macro.njk" import govukPanel %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% macro successPanel(title='', text='') %}
  {{ govukPanel({
    titleText: title,
    text: text
  }) }}
{% endmacro %}

{# Address Block #}
{% macro addressBlock(address, asRow=false) %}
  {%- if asRow %}
    {{ address.addressLine1 }}, {%- if address.addressLine2 %} {{ address.addressLine2 }}, {% endif -%} {{ address.townCity }}, {%- if address.county %} {{ address.county }}, {% endif -%} {{ address.postcode }}
  {% else %}
    <p class="govuk-body govuk-!-margin-bottom-1">{{ address.addressLine1 }}</p>
    {% if address.addressLine2 %}
      <p class="govuk-body govuk-!-margin-bottom-1">{{ address.addressLine2 }}</p>
    {% endif %}
    <p class="govuk-body govuk-!-margin-bottom-1">{{ address.townCity }}</p>
    {% if address.county %}
      <p class="govuk-body govuk-!-margin-bottom-1">{{ address.county }}</p>
    {% endif %}
    <p class="govuk-body govuk-!-margin-bottom-0">{{ address.postcode }}</p>
  {% endif -%}
{% endmacro %}

{# presentable format of the addressType #}
{% macro addressType(address) %}
  {%- if address.addressType === "WRITE_TO_US" %}
    Send documents to
  {% elseif address.addressType === "VISIT_OR_CONTACT_US" %}
    Visit and send documents to
  {% else %} {# visit us #}
    Visit
  {% endif -%}
{% endmacro %}

{# common error summary/linking for templates where we #}
{# explicitly map field ids to schema keys #}
{% macro modelDrivenErrorSummary(modelErrors) %}
  {% set errorList = [] %}
  {% for field, errors in modelErrors %}
    {% for error in errors %}
      {% set href = "#" + field if field !== "message" else null %}
      {% set errorList = (errorList.push({
        text: error,
        href: href
      }), errorList) %}
    {% endfor %}
  {% endfor %}
  {{ govukErrorSummary({
    titleText: "There is a problem",
    errorList: errorList
  }) }}
{% endmacro %}

{# Generic row actions list for table/list action links #}
{% macro rowActions(items) %}
  <ul class="govuk-summary-list__actions-list govuk-!-margin-bottom-0">
    {% for item in items %}
      {%- if item and item.href %}
        <li class="govuk-summary-list__actions-list-item">
          <a class="govuk-link govuk-link--no-visited-state" href="{{ item.href }}">{{ item.text }}</a>
        </li>
      {% endif -%}
    {% endfor %}
  </ul>
{% endmacro %}
