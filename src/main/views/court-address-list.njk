{% extends "template.njk" %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "macros/common-components.njk" import addressBlock, addressType %}

{#  MACROS #}

{# Row actions - in the form "action1 | action2 | actionN" #}
{% macro rowActions(items) %}
  <ul class="govuk-summary-list__actions-list govuk-!-margin-bottom-0">
    {% for item in items %}
      <li class="govuk-summary-list__actions-list-item">
        <a class="govuk-link govuk-link--no-visited-state" href="{{ item.href }}">{{ item.text }}</a>
      </li>
    {% endfor %}
  </ul>
{% endmacro %}

{#  END OF MACROS #}


{% block pageTitle %}
  {{ pageTitle }}
{% endblock %}

{% block content %}

  {% set addressTableRows = [] %}
  {% if courtAddresses.length %}
    {% for address in courtAddresses %}
      {% set addressTableRows = (addressTableRows.push([
        {
          html: addressType(address)
        },
        {
          html: addressBlock(address)
        },
        {
          html: rowActions([
            {
              href: '/courts/' + address.courtId + '/edit/address/find/' + address.id,
              text: 'Edit'
            },
            {
              href: '/courts/' + address.courtId + '/edit/address/delete/' + address.id,
              text: 'Delete'
            }
          ])
        }
      ]), addressTableRows) %}
    {% endfor %}
  {% endif %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <h1 class="govuk-heading-l">Addresses</h1>
      {% if addressTableRows.length %}
        {{ govukTable({
          firstCellIsHeader: false,
          head: [
            {
              text: "Description",
              classes: "govuk-!-width-one-quarter"
            },
            {
              text: "Address",
              classes: "govuk-!-width-one-half"
            },
            {
              text: "Action",
              classes: "govuk-!-width-one-quarter"
            }
          ],
          rows: addressTableRows
        }) }}
      {% else %}
        <p class="govuk-body">No addresses are currently configured.</p>
      {% endif %}
    </div>
  </div>
{% endblock %}
