{% extends "govuk/template.njk" %}
{% from "govuk/components/service-navigation/macro.njk" import govukServiceNavigation %}

{% block head %}
  {% include "webpack/css.njk" %}
{% endblock %}

{% block header %}
  {{ govukHeader({
    homepageUrl: "/"
  }) }}
  {{ govukServiceNavigation({
    serviceName: "Find a Court or Tribunal Admin",
    serviceUrl: "/",
    navigation: [
      {
        href: "/",
        text: "Courts"
      },
      {
        href: "/download",
        text: "Download csv"
      },
      {
        href: "/add-court",
        text: "Add new court"
      },
      {
        href: "/audits",
        text: "Audit"
      },
      {
        href: "/users",
        text: "Users"
      }
    ]
  }) }}
{% endblock %}

{% block footer %}
  {{ govukFooter({}) }}
{% endblock %}

{% block bodyEnd %}
  {# Run JavaScript at end of the <body>, to avoid blocking the initial render. #}
  {% include "webpack/js.njk" %}
{% endblock %}
