{% extends "template.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{% block pageTitle %}
  {{ pageTitle }}
{% endblock %}

{% block content %}
  {% set editPath = '/service-centres/' + serviceCentreId + '/edit' %}
  {% set sections = [
    { href: editPath + '/general', label: 'General', status: 'TODO' },
    { href: editPath + '/warning-notice', label: 'Warning notice', status: 'TODO' },
    { href: editPath + '/address', label: 'Address', status: 'TODO' },
    { href: editPath + '/contact-details', label: 'Contact details', status: 'TODO' },
    { href: editPath + '/cases-heard', label: 'Cases heard', status: 'TODO' }
  ] %}
  {% set sectionRows = [] %}
  {% for section in sections %}
    {% set statusId = "service-centre-edit-" + loop.index + "-status" %}
    {% set sectionRows = (sectionRows.push([
      {
        html: '<a class="govuk-link" href="' + section.href + '" aria-describedby="' + statusId + '">' + section.label + '</a>'
      },
      {
        html: '<span id="' + statusId + '">' + govukTag({
          text: section.status,
          classes: "govuk-tag--grey"
        }) + '</span>'
      }
    ]), sectionRows) %}
  {% endfor %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      <h1 class="govuk-heading-l">Editing service centre</h1>
      <div class="court-edit-table__wrapper">
        {{ govukTable({
          classes: "court-edit-table",
          firstCellIsHeader: false,
          rows: sectionRows
        }) }}
      </div>
      {% if showApproveData %}
        <section class="govuk-!-margin-top-8" aria-labelledby="approve-data-heading">
          <h2 class="govuk-heading-m" id="approve-data-heading">Approve data</h2>
          <p class="govuk-body">
            Once you have reviewed all the inputted data for this court/service centre/tribunal, please approve.
            If the data is incorrect, please contact the NSU to update it. nationalsupportunit@justice.gov.uk
          </p>
          {{ govukButton({
            text: "Approve data",
            href: approvePath
          }) }}
        </section>
      {% endif %}
    </div>
  </div>
{% endblock %}
