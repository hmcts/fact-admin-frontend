{% extends "template.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/select/macro.njk" import govukSelect %}

{% block pageTitle %}
  {{ pageTitle }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">Add contact details</h1>
      <form action="/courts/{{ courtId }}/edit/contact-details/add/success" method="post" novalidate>
        {{ govukSelect({
          id: "contact-type",
          name: "contact-type",
          label: {
            text: "Contact type"
          },
          items: [
            { value: "", text: "Select" },
            { value: "general-enquiries-phone", text: "General enquiries" },
            { value: "general-enquiries-email", text: "General enquiries" },
            { value: "listing-enquiries", text: "Listing enquiries" },
            { value: "emergency-out-of-hours", text: "Emergency out of hours" },
            { value: "welsh-language-line", text: "Welsh language line" },
            { value: "other", text: "Other" }
          ]
        }) }}

        {{ govukInput({
          label: {
            text: "Explanation (optional)"
          },
          hint: {
            text: "Add a short explanation if required. For example, 'Breathing Spaces gives someone in debt the right to legal protections'."
          },
          id: "contact-explanation",
          name: "contact-explanation",
          type: "text"
        }) }}

        {{ govukCheckboxes({
          idPrefix: "contact-methods",
          name: "contact-methods",
          fieldset: {
            legend: {
              text: "Select all that apply",
              classes: "govuk-fieldset__legend--m"
            }
          },
          items: [
            {
              value: "email",
              text: "Email address",
              conditional: {
                html: govukInput({
                  id: "contact-email",
                  name: "contact-email",
                  type: "email",
                  label: { text: "Email address", classes: "govuk-visually-hidden" },
                  hint: { text: "Write email address in full and in lower case." }
                })
              }
            },
            {
              value: "phone",
              text: "Phone number",
              conditional: {
                html: govukInput({
                  id: "contact-telephone",
                  name: "contact-telephone",
                  type: "tel",
                  label: { text: "Phone number", classes: "govuk-visually-hidden" },
                  hint: { text: "Use space between city and local exchange. For example, 01273 800 900 or 020 7450 4000." }
                })
              }
            }
          ]
        }) }}

        {{ govukButton({
          text: "Save"
        }) }}
      </form>
    </div>
  </div>
{% endblock %}

