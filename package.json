{
  "name": "fact-admin-frontend",
  "description": "Admin Frontend for the Find a Court or Tribunal service",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "start": "NODE_ENV=production ts-node --transpile-only -r tsconfig-paths/register src/main/server.ts",
    "start:dev": "node ./scripts/dev-watcher.js",
    "lint": "NODE_OPTIONS=--no-warnings stylelint **/*.scss -v -q && eslint . --ext .js,.ts && prettier --check .",
    "lint:fix": "prettier --write . .github && eslint --fix .",
    "build": "yarn webpack --config webpack.config.js",
    "build:prod": "NODE_ENV=production yarn webpack --mode production --config webpack.config.js",
    "test": "npx if-env CI=true && exit 0 || yarn test:unit",
    "test:unit": "jest",
    "test:coverage": "jest --coverage",
    "test:routes": "jest -c jest.routes.config.js",
    "test:smoke": "yarn playwright test --grep @smoke",
    "test:functional": "yarn playwright test --grep-invert='@smoke'",
    "test:performance": "yarn playwright test --grep='@performance'",
    "test:a11y": "echo 'a11y tests run as part of test:functional' && exit 0",
    "cichecks": "yarn install && yarn build && yarn rebuild puppeteer && yarn lint && yarn test && yarn test:routes && yarn test:a11y",
    "prepare": "husky install"
  },
  "dependencies": {
    "@azure/identity": "4.13.1",
    "@hmcts/info-provider": "^1.4.0",
    "@hmcts/nodejs-healthcheck": "1.8.6",
    "@hmcts/nodejs-logging": "^4.0.4",
    "@hmcts/properties-volume": "1.4.0",
    "applicationinsights": "3.15.0",
    "async-mutex": "0.5.0",
    "awilix": "12.1.1",
    "awilix-express": "11.0.1",
    "axios": "1.16.1",
    "config": "4.4.1",
    "cookie-parser": "1.4.7",
    "express": "5.2.1",
    "express-openid-connect": "3.0.0",
    "express-rate-limit": "8.5.2",
    "govuk-frontend": "5.14.0",
    "helmet": "8.1.0",
    "lodash": "4.18.1",
    "nunjucks": "3.2.4",
    "redis": "^5.11.0",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@babel/core": "7.29.7",
    "@babel/plugin-proposal-decorators": "7.29.7",
    "@babel/preset-env": "7.29.7",
    "@babel/preset-typescript": "7.29.7",
    "@codeceptjs/allure-legacy": "^1.0.2",
    "@codeceptjs/configure": "1.0.6",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@hmcts/playwright-common": "^1.1.2",
    "@playwright/test": "1.60.0",
    "@types/babel__preset-env": "7.10.0",
    "@types/chai": "^5.2.3",
    "@types/chai-as-promised": "8.0.2",
    "@types/config": "3.3.5",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/govuk-frontend": "^5.11.0",
    "@types/jest": "^30.0.0",
    "@types/lodash": "4.17.24",
    "@types/node": "22.19.19",
    "@types/nunjucks": "3.2.6",
    "@types/pa11y": "^5.3.7",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "8.59.4",
    "@typescript-eslint/parser": "8.59.4",
    "babel-jest": "30.4.1",
    "chai": "6.2.2",
    "codeceptjs": "^3.7.9",
    "copy-webpack-plugin": "13.0.1",
    "css-loader": "7.1.4",
    "debug": "4.4.3",
    "dotenv": "^17.4.2",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.15.2",
    "get-port": "^7.2.0",
    "globals": "17.6.0",
    "html-webpack-plugin": "5.6.7",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "jest-html-reporter": "4.4.0",
    "lighthouse": "13.3.0",
    "lint-staged": "16.4.0",
    "mini-css-extract-plugin": "2.10.2",
    "odhin-reports-playwright": "1.1.8",
    "pa11y": "9.1.1",
    "playwright": "1.60.0",
    "playwright-core": "1.60.0",
    "playwright-lighthouse": "^4.0.0",
    "prettier": "3.8.3",
    "sass": "1.99.0",
    "sass-loader": "16.0.8",
    "sinon": "21.1.2",
    "style-loader": "4.0.0",
    "stylelint": "17.11.1",
    "supertest": "^7.2.2",
    "ts-jest": "29.4.10",
    "ts-loader": "9.5.7",
    "webpack": "5.106.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-middleware": "6.1.3"
  },
  "resolutions": {
    "@opentelemetry/exporter-prometheus": "0.218.0",
    "@opentelemetry/sdk-node": "0.218.0",
    "uuid": "14.0.0",
    "protobufjs": "7.6.1",
    "ip-address": "10.2.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown",
    "**/*.{js,ts}": "eslint --fix"
  },
  "packageManager": "yarn@4.15.0"
}
