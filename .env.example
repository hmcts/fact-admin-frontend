# ----------------------------------------------------------------------------
# FaCT Data API URL
# ----------------------------------------------------------------------------
DATA_API_URL=http://localhost:8989/

# ----------------------------------------------------------------------------
# Auth settings for Admin pages
# ----------------------------------------------------------------------------
# CJS Common Platform tenant ID
AZURE_TENANT_ID=<tenant-id>
# Admin (non-prod) App Registration Application (client) ID
AZURE_CLIENT_ID=<client-id>
# Admin (non-prod) App Registration Application Client Secret
AZURE_CLIENT_SECRET==<client-secret>
# FaCT Data API (non-prod) App Registration Application (client) ID
API_APP_REG_ID=<api-app-reg-id>

# ----------------------------------------------------------------------------
# Access URLs for Admin pages
# ----------------------------------------------------------------------------
ADMIN_URL=http://localhost:3355/
ADMIN_DASHBOARD_URL=http://localhost:3355/dashboard

# ----------------------------------------------------------------------------
# Playwright settings
# ----------------------------------------------------------------------------
PLAYWRIGHT_REPORTERS=list,odhin
PW_ODHIN_PROJECT=fact-admin-frontend
PLAYWRIGHT_VIDEO_MODE=retain-on-failure

# testing
ADMIN_SSO_ID=admin
SUPER_ADMIN_SSO_ID=super_admin
